# Public hosted checkout destinations only. Never place provider credentials in VITE_ variables.
VITE_RESERVATION_CHECKOUT_URL=
VITE_EVIDENCE_CHECKOUT_URL=

# Temporary release source when the canonical npm package is not yet published.
# Example: npx -y github:owner/scopeparity-cli
VITE_CLI_PREFIX=

# Compatibility fallback for the evidence-pack checkout only.
VITE_CHECKOUT_URL=
